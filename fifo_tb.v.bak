`timescale 1ns/1ps
module fifo_tb;
    parameter W = 8;
    parameter L = 8;

    reg clk, reset, wr_en, rd_en;
    reg [W-1:0] wr_data;
    wire [W-1:0] rd_data;
    wire empty, full;

    fifo #(W,L) dut(
        .clk(clk),
        .reset(reset),
        .wr_en(wr_en),
        .rd_en(rd_en),
        .wr_data(wr_data),
        .rd_data(rd_data),
        .empty(empty),
        .full(full)
    );

    // Clock
    initial clk = 0;
    always #5 clk = ~clk;

    // Monitor
    initial begin
        $monitor("Time=%0t | wr_en=%b rd_en=%b | wr_data=%d rd_data=%d | empty=%b full=%b",
                 $time, wr_en, rd_en, wr_data, rd_data, empty, full);
    end

    initial begin
        reset = 0;
        wr_en = 0; rd_en = 0;
        wr_data = 0;
        #20 reset = 1;

        //Test case: Ghi dữ liệu
        repeat(L) begin
            @(posedge clk);
            wr_en = 1;
            wr_data = wr_data + 1;
        end
        @(posedge clk);
        wr_en = 0;

        //Test case: Đọc dữ liệu
        repeat(L) begin
            @(posedge clk);
            rd_en = 1;
        end
        @(posedge clk);
        rd_en = 0;
        
        #20 $stop;
    end
endmodule
