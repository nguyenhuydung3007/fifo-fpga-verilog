transcript on
if {[file exists rtl_work]} {
	vdel -lib rtl_work -all
}
vlib rtl_work
vmap work rtl_work

vlog -vlog01compat -work work +incdir+D:/1.FPGA/2.Project_VSCode/3.FIFO/src {D:/1.FPGA/2.Project_VSCode/3.FIFO/src/fifo.v}

vlog -vlog01compat -work work +incdir+D:/1.FPGA/1.Project_Quatus/9.FIFO/../../2.Project_VSCode/3.FIFO/src {D:/1.FPGA/1.Project_Quatus/9.FIFO/../../2.Project_VSCode/3.FIFO/src/fifo_tb.v}

vsim -t 1ps -L altera_ver -L lpm_ver -L sgate_ver -L altera_mf_ver -L altera_lnsim_ver -L fiftyfivenm_ver -L rtl_work -L work -voptargs="+acc"  fifo_tb

add wave *
view structure
view signals
run -all
